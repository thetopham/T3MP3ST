{
  "id": "t3mp3st-maintainer",
  "type": "addon",
  "name": "t3mp3st-maintainer",
  "version": "0.1.0",
  "description": "Project-local maintainer operations for T3MP3ST PR, issue, and release stewardship.",
  "manifestVersion": "1",
  "platforms": {
    "claude": "full",
    "codex": "full"
  },
  "keywords": [
    "t3mp3st",
    "maintainer",
    "pull-requests",
    "issues",
    "merge-train",
    "ops"
  ],
  "deployment": {
    "pathTemplate": ".{platform}/skills/{id}.md"
  },
  "addonConfig": {
    "entry": {
      "skills": "skills/",
      "agents": "agents/"
    }
  }
}
